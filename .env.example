# ─── Database ──────────────────────────────────────────────────────────────
# Local dev (no Docker): uses OS trust auth
DATABASE_URL=postgresql://user@localhost/medical_rag

# Docker: docker-compose overrides DATABASE_URL automatically using this password.
# PRODUCTION: use a strong random secret and store it in AWS Secrets Manager.
POSTGRES_PASSWORD=changeme


# ─── LLM / Embedding ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# Optional: set to use a different OpenAI-compatible provider (e.g. Azure, Ollama)
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1


# ─── Web Search ────────────────────────────────────────────────────────────
# Tavily is the web-search provider. Required for the web_search node.
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-your-key-here


# ─── Security ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# PRODUCTION: set to your CloudFront / frontend domain.
# Leave as-is for local development.
ALLOWED_ORIGINS=http://localhost:3000

# Optional API key for /api/query endpoints (X-API-Key header).
# Leave empty to disable auth during local development.
# PRODUCTION: set to a strong random secret.
API_KEY=


# ─── Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info


# ─── Conversation history ──────────────────────────────────────────────────
# Maximum number of conversation turns to load into the context window.
# Note: token-aware truncation is applied on top of this limit.
MAX_HISTORY_TURNS=10


# ─── PubMed (optional, increases rate limit from 3 req/s to 10 req/s) ─────
# Register at https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=your-ncbi-key-here
